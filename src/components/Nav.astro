---
const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname.startsWith(path);
---

<header>
  <nav>
    <a href="/" class="site-name">Taichi Kamei</a>
    <ul>
      <li><a href="/" class:list={['nav-link', { active: isActive('/') }]}>About</a></li>
      <li><a href="/projects" class:list={['nav-link', { active: isActive('/projects') }]}>Projects</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(121, 174, 163, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gap);
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-weight: 600;
    font-size: 1.15rem;
    text-decoration: none;
    letter-spacing: -0.01em;
    color: #fff;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    text-decoration: none;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-link.active {
    color: #fff;
    font-weight: 500;
  }
</style>
