  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg-subtle: #f5f5f5;
    --border: #e5e5e5;
    --text: #111111;
    --text-muted: #666666;
    --text-faint: #999999;
    --accent: #111111;
    --font: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
    --max-w: 900px;
    --gap: 2rem;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a { color: inherit; }

  h1, h2, h3, h4 { line-height: 1.25; font-weight: 600; }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-subtle);
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  /* image-row utility used in project markdown */
  .image-row {
    display: flex;
    gap: 0.75rem;
    margin: 1.25rem 0;
    flex-wrap: wrap;
  }
  .image-row img {
    flex: 1 1 0;
    min-width: 0;
    max-height: 360px;
    object-fit: contain;
    background: var(--bg-subtle);
  }

  .pdf-embed {
    margin: 1.5rem 0;
  }

  .social-sidebar {
    position: fixed;
    right: 30px;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 50;
  }

  .social-sidebar a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: #555;
    text-decoration: none;
    background: var(--bg);
    border: 1px solid var(--border);
    transition: color 0.15s, border-color 0.15s;
  }

  .social-sidebar a:hover {
    color: var(--text);
    border-color: #999;
  }

  @media (max-width: 640px) {
    .social-sidebar { display: none; }
  }
</style>
