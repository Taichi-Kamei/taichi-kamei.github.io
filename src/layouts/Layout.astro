---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Taichi Kamei', description = 'Engineering portfolio' } = Astro.props;
const fullTitle = title === 'Taichi Kamei' ? title : `${title} — Taichi Kamei`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/T.svg" type="image/svg+xml" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />

    <div class="social-sidebar">
      <a href="https://github.com/Taichi-Kamei" target="_blank" rel="noopener" aria-label="GitHub">
